@page "/"
@using PetShop.DTO
@using System.Net.Http.Json
@inject HttpClient Http

<PageTitle>Dashboard - Thống kê</PageTitle>

<div class="container-fluid">
    <h3 class="text-primary mb-4 fw-bold">
        <i class="bi bi-speedometer2 me-2"></i> TỔNG QUAN TÌNH HÌNH
    </h3>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card bg-primary text-white shadow-sm h-100">
                <div class="card-body">
                    <h6 class="card-title opacity-75">TỔNG DOANH THU BÁN LẺ</h6>
                    <h3 class="fw-bold">@TotalRevenue.ToString("#,##0") đ</h3>
                    <small><i class="bi bi-graph-up-arrow"></i> Đã thanh toán</small>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card bg-warning text-dark shadow-sm h-100">
                <div class="card-body">
                    <h6 class="card-title opacity-75">LỊCH HẸN CHỜ XỬ LÝ</h6>
                    <h3 class="fw-bold">@PendingCount</h3>
                    <small>Cần xác nhận ngay</small>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card bg-success text-white shadow-sm h-100">
                <div class="card-body">
                    <h6 class="card-title opacity-75">KHÁCH HÀNG</h6>
                    <h3 class="fw-bold">@CustomerCount</h3>
                    <small><i class="bi bi-people-fill"></i> Tổng số khách</small>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card bg-danger text-white shadow-sm h-100">
                <div class="card-body">
                    <h6 class="card-title opacity-75">SẢN PHẨM SẮP HẾT</h6>
                    <h3 class="fw-bold">@LowStockCount</h3>
                    <small>Cần nhập thêm hàng</small>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-6">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-white fw-bold">
                    <i class="bi bi-pie-chart-fill me-2 text-primary"></i> Tỉ lệ Thú Cưng theo Loài
                </div>
                <div class="card-body d-flex flex-column align-items-center justify-content-center">
                    <h5 class="text-center mb-3">Tổng cộng: <span class="fw-bold text-primary">@pets.Count</span> bé</h5>

                    <div style="width: 100%; height: 300px;">
                        <canvas id="petTypeChart"></canvas>
                    </div>

                    @if (!TypeStats.Any())
                    {
                        <p class="text-center text-muted mt-3">Chưa có dữ liệu thống kê.</p>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow-sm h-100 border-danger">
                <div class="card-header bg-danger text-white fw-bold">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> Cảnh Báo Nhập Kho (Dưới 10)
                </div>
                <div class="card-body p-0 table-responsive">
                    <table class="table table-striped mb-0">
                        <thead>
                            <tr>
                                <th>Sản phẩm</th>
                                <th class="text-center">Tồn</th>
                                <th class="text-end">Giá bán</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in LowStockProducts)
                            {
                                <tr>
                                    <td>@p.product_name</td>
                                    <td class="text-center fw-bold text-danger">@p.stock_quantity</td>
                                    <td class="text-end">@p.selling_price.ToString("#,##0")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Inject] IJSRuntime JSRuntime { get; set; }
    private List<AppointmentDisplay> appointments = new();
    private List<ProductDisplay> products = new();
    private List<CustomerDisplay> customers = new();
    private List<OrderDisplay> orders = new();
    private List<PetDisplay> pets = new();

    private List<TypeStat> TypeStats = new();
    private List<ProductDisplay> LowStockProducts = new();

    private int PendingCount = 0, CustomerCount = 0, LowStockCount = 0;
    private decimal TotalRevenue = 0;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (TypeStats.Any())
        {
            await RenderChart();
        }
    }

    private async Task RenderChart()
    {
        try
        {
            var labels = TypeStats.Select(s => s.Name).ToArray();
            var data = TypeStats.Select(s => s.Count).ToArray();
            

            var colorsMap = new Dictionary<string, string>
            {
                { "primary", "#0d6efd" },
                { "success", "#198754" },
                { "warning", "#ffc107" },
                { "danger", "#dc3545" },
                { "info", "#0dcaf0" },
                { "secondary", "#6c757d" },
                { "dark", "#212529" }
            };
            var backgroundColors = TypeStats.Select(s => colorsMap.ContainsKey(s.ColorClass) ? colorsMap[s.ColorClass] : "#cccccc").ToArray();

            await JSRuntime.InvokeVoidAsync("chartHelper.createPieChart", "petTypeChart", labels, data, backgroundColors);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Lỗi vẽ biểu đồ: {ex.Message}");
        }
    }

    public class TypeStat
    {
        public string Name { get; set; } = "";
        public int Count { get; set; }
        public double Percent { get; set; }
        public string ColorClass { get; set; } = "primary";
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {

            var t1 = Http.GetFromJsonAsync<List<CustomerDisplay>>("/api/customers");
            var t2 = Http.GetFromJsonAsync<List<AppointmentDisplay>>("/api/appointments");
            var t3 = Http.GetFromJsonAsync<List<ProductDisplay>>("/api/products");
            var t4 = Http.GetFromJsonAsync<List<OrderDisplay>>("/api/orders");
            var t5 = Http.GetFromJsonAsync<List<PetDisplay>>("/api/pets");


            await Task.WhenAll(t1, t2, t3, t4, t5);

            customers = await t1 ?? new();
            appointments = await t2 ?? new();
            products = await t3 ?? new();
            orders = await t4 ?? new();
            pets = await t5 ?? new();

            CalculateStats();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Lỗi load dữ liệu Dashboard: {ex.Message}");

            customers ??= new();
            appointments ??= new();
            products ??= new();
            orders ??= new();
            pets ??= new();
        }
    }

    private void CalculateStats()
    {

        CustomerCount = customers?.Count ?? 0;


        PendingCount = appointments?.Count(a => a.appointment_status == "Confirmed" || a.appointment_status == "In Progress") ?? 0;

        TotalRevenue = orders?.Where(o => o.payment_status == "Completed" || o.payment_status == "Đã thanh toán")
                             .Sum(o => o.total_amount) ?? 0;

        LowStockProducts = products?.Where(p => p.stock_quantity < 10).ToList() ?? new();
        LowStockCount = LowStockProducts.Count;

        TypeStats.Clear();
        if (pets != null && pets.Any())
        {
            var groupedPets = pets.GroupBy(p => string.IsNullOrEmpty(p.species) ? "Khác" : p.species).ToList();
            string[] colors = { "primary", "success", "warning", "danger", "info", "secondary", "dark" };
            int i = 0;

            foreach (var group in groupedPets)
            {
                TypeStats.Add(new TypeStat
                    {
                        Name = group.Key,
                        Count = group.Count(),

                        Percent = pets.Count > 0 ? (double)group.Count() / pets.Count * 100 : 0,
                        ColorClass = colors[i % colors.Length]
                    });
                i++;
            }
        }
    }
}
