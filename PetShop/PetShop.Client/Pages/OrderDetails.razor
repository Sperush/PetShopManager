@page "/order-details/{id:int}"
<PageTitle>Chi Tiết Hóa Đơn</PageTitle>
@using PetShop.DTO
@inject HttpClient Http
@inject NavigationManager Nav

<div class="container mt-4">
    <button class="btn btn-outline-secondary mb-3" @onclick="GoBack">
        <i class="bi bi-arrow-left"></i> Quay lại danh sách
    </button>

    @if (order == null)
    {
        <div class="text-center"><div class="spinner-border"></div> Đang tải hóa đơn...</div>
    }
    else
    {
        <div class="card shadow border-0">
            <div class="card-header @(order.payment_status == "Completed" ? "bg-success" : (order.payment_status == "Cancelled" ? "bg-danger" : "bg-warning")) text-white d-flex justify-content-between align-items-center py-3">
                <h4 class="mb-0 fw-bold"><i class="bi bi-receipt"></i> HÓA ĐƠN BÁN LẺ #@order.order_id</h4>
                <div class="d-flex gap-2">
                    @if (order.payment_status == "Pending")
                    {
                        <button class="btn btn-light text-success fw-bold px-4" @onclick="ConfirmPayment">
                            <i class="bi bi-check-circle-fill me-1"></i> XÁC NHẬN THANH TOÁN
                        </button>
                        <button class="btn btn-outline-light fw-bold" @onclick="CancelOrder">
                            <i class="bi bi-x-circle me-1"></i> HỦY ĐƠN
                        </button>
                    }
                    else
                    {
                        <span class="badge bg-light @(order.payment_status == "Completed" ? "text-success" : "text-danger") fw-bold px-3 py-2">
                            <i class="bi @(order.payment_status == "Completed" ? "bi-check-circle" : "bi-x-circle") me-1"></i>
                            @order.payment_status.ToUpper()
                        </span>
                    }
                </div>
            </div>
            <div class="card-body">
                <div class="row mb-4">
                    <div class="col-md-6">
                        <h5 class="text-success border-bottom pb-2">Thông Tin Khách Hàng</h5>
                        <p class="mb-1"><strong>Họ tên:</strong> @order.customer_name <span class="text-muted small">(ID: @order.customer_id)</span></p>
                        <p class="mb-1"><strong>Số điện thoại:</strong> @(string.IsNullOrEmpty(order.customer_phone) ? "N/A" : order.customer_phone)</p>
                        <p class="mb-1"><strong>Địa chỉ:</strong> @(string.IsNullOrEmpty(order.customer_address) ? "N/A" : order.customer_address)</p>
                    </div>
                    <div class="col-md-6 text-md-end">
                        <h5 class="text-success border-bottom pb-2">Thông Tin Giao Dịch</h5>
                        <p class="mb-1"><strong>Ngày tạo:</strong> @order.created_time.ToString("dd/MM/yyyy HH:mm")</p>

                        <p class="mb-1">
                            <strong>Lúc thanh toán:</strong>
                            @(order.payment_time.HasValue ? order.payment_time.Value.ToString("dd/MM/yyyy HH:mm") : "Chưa thanh toán")
                        </p>

                        <p class="mb-1"><strong>PT Thanh toán:</strong> @order.payment_method</p>
                        <p class="mb-1"><strong>Thu ngân:</strong> @order.employee_name <span class="text-muted small">(Ca: @order.workshift_id)</span></p>
                    </div>
                </div>

                <h5 class="text-success border-bottom pb-2">Danh Sách Sản Phẩm</h5>
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>Sản Phẩm</th>
                                <th class="text-center">Số Lượng</th>
                                <th class="text-end">Đơn Giá</th>
                                <th class="text-end">Thành Tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (order.Details != null)
                            {
                                @foreach (var item in order.Details)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-bold">@item.product_name</div>

                                            @if (!string.IsNullOrEmpty(item.note))
                                            {
                                                <div class="small text-muted fst-italic mt-1">
                                                    <i class="bi bi-chat-text me-1"></i> Ghi chú: @item.note
                                                </div>
                                            }
                                        </td>
                                        <td class="text-center">@item.quantity</td>
                                        <td class="text-end">@item.price_at_purchase.ToString("#,##0") đ</td>
                                        <td class="text-end fw-bold">@item.TotalPrice.ToString("#,##0") đ</td>
                                    </tr>
                                }
                            }
                        </tbody>
                        <tfoot class="table-light">
                            @if (order.used_reward_points > 0)
                            {
                                <tr>
                                    <td colspan="3" class="text-end text-muted">Sử dụng điểm thưởng:</td>
                                    <td class="text-end text-success fw-bold">
                                        - @order.used_reward_points điểm
                                    </td>
                                </tr>
                            }
                            <tr>
                                <td colspan="3" class="text-end fw-bold">TỔNG CỘNG THANH TOÁN:</td>
                                <td class="text-end fw-bold text-danger fs-5">
                                    @order.total_amount.ToString("#,##0") đ
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
            <div class="card-footer bg-white text-center text-muted small">
                Cảm ơn quý khách đã mua sắm tại PetShop!
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int Id { get; set; }
    private OrderFullDisplay? order;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            order = await Http.GetFromJsonAsync<OrderFullDisplay>($"/api/orders/{Id}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Lỗi: {ex.Message}");
        }
    }

    private void GoBack() => Nav.NavigateTo("/orders");

    private async Task ConfirmPayment()
    {
        if (order == null) return;
        var res = await Http.PostAsync($"/api/orders/{order.order_id}/status?status=Completed", null);
        if (res.IsSuccessStatusCode)
        {
            order = await Http.GetFromJsonAsync<OrderFullDisplay>($"/api/orders/{Id}");
            StateHasChanged();
        }
    }

    private async Task CancelOrder()
    {
        if (order == null) return;
        var res = await Http.PostAsync($"/api/orders/{order.order_id}/status?status=Cancelled", null);
        if (res.IsSuccessStatusCode)
        {
            order = await Http.GetFromJsonAsync<OrderFullDisplay>($"/api/orders/{Id}");
            StateHasChanged();
        }
    }
}

