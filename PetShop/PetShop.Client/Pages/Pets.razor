@page "/pets"
<PageTitle>Thú Cưng</PageTitle>
@using PetShop.DTO
@using System.Net.Http.Json
@inject HttpClient Http

<h3 class="text-primary mb-4"><i class="bi bi-github me-2"></i> QUẢN LÝ HỒ SƠ THÚ CƯNG</h3>

<div class="card p-3 mb-5 shadow-sm bg-light">
    <div class="row g-3 align-items-start mb-3">
        <div class="col-md-3">
            <label class="form-label fw-bold small">Chủ Sở Hữu</label>
            @if (currentPet.customer_id == 0)
            {
                <div class="position-relative">
                    <div class="input-group">
                        <input class="form-control"
                               placeholder="Tìm theo ID hoặc Tên KH..."
                               @bind="ownerSearchKeyword"
                               @bind:event="oninput"
                               @onkeyup="SearchOwner" />
                    </div>

                    @if (suggestedCustomers.Any())
                    {
                        <div class="list-group position-absolute w-100 shadow" style="z-index: 1000; max-height: 200px; overflow-y: auto;">
                            @foreach (var c in suggestedCustomers)
                            {
                                <button type="button" class="list-group-item list-group-item-action" @onclick="() => SelectOwner(c)">
                                    <div class="d-flex justify-content-between">
                                        <strong>ID: @c.customer_id - @c.FullName</strong>
                                        <small class="text-muted">@c.phone</small>
                                    </div>
                                </button>
                            }
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="input-group">
                    <span class="form-control bg-white text-primary fw-bold">
                        <i class="bi bi-person-check-fill"></i> @selectedOwnerName
                    </span>
                    <button class="btn btn-outline-danger" type="button" @onclick="RemoveOwner">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
            }
        </div>

        <div class="col-md-2">
            <label class="form-label fw-bold small">Tên thú cưng</label>
            <input @bind="currentPet.pet_name" class="form-control" placeholder="VD: Miu..." />
        </div>

        <div class="col-md-2">
            <label class="form-label fw-bold small">Loài</label>
            <select @bind="currentPet.species" class="form-select">
                <option value="">Chọn</option>
                <option value="Mèo">Mèo</option>
                <option value="Chó">Chó</option>
                <option value="Khác">Khác</option>
            </select>
        </div>

        <div class="col-md-3">
            <label class="form-label fw-bold small">Giống</label>
            <input @bind="currentPet.breed" class="form-control" placeholder="VD: Poodle, Corgi..." />
        </div>

        <div class="col-md-2">
            <label class="form-label fw-bold small">Giới tính</label>
            <select @bind="currentPet.gender" class="form-select">
                <option value="">Chọn</option>
                <option value="Đực">Đực</option>
                <option value="Cái">Cái</option>
                <option value="Khác">Khác</option>
            </select>
        </div>
    </div>

    <div class="row g-3 align-items-end">
        <div class="col-md-2">
            <label class="form-label fw-bold small">Màu sắc</label>
            <input @bind="currentPet.color" class="form-control" placeholder="VD: Nâu, Trắng..." />
        </div>

        <div class="col-md-2">
            <label class="form-label fw-bold small">Cân nặng (kg)</label>
            <input @bind="currentPet.weight" type="number" step="0.1" class="form-control" />
        </div>

        <div class="col-md-2">
            <label class="form-label fw-bold small">Ngày sinh</label>
            <input id="pet_birth_date_picker" @bind="currentPet.birth_date" type="text" class="form-control" placeholder="Chọn ngày sinh..." />
        </div>

        <div class="col-md-4">
            <label class="form-label fw-bold small">Ghi chú</label>
            <input @bind="currentPet.note" class="form-control" placeholder="Thông tin thêm..." />
        </div>

        <div class="col-md-2">
            @if (isEditing)
            {
                <div class="btn-group w-100">
                    <button class="btn btn-success" @onclick="SavePet"><i class="bi bi-check-lg"></i> Lưu</button>
                    <button class="btn btn-secondary" @onclick="CancelEdit">Hủy</button>
                </div>
            }
            else
            {
                <button class="btn btn-primary w-100" @onclick="SavePet"><i class="bi bi-plus-lg"></i> Thêm Mới</button>
            }
        </div>
    </div>
</div>

<div class="input-group mb-3 w-50">
    <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
    <input class="form-control" placeholder="Tìm theo ID Khách hoặc Tên thú cưng..." @bind="searchText" @bind:event="oninput" />
</div>

<table class="table table-bordered table-hover align-middle shadow-sm">
    <thead class="table-primary text-center">
        <tr>
            <th>ID</th>
            <th>Tên</th>
            <th>Thông Tin Bé</th>
            <th>Đặc Điểm</th>
            <th>Ghi Chú</th>
            <th>Chủ Sở Hữu</th>
            <th>Thao Tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var p in PagedPets)
        {
            <tr>
                <td class="text-center fw-bold text-secondary">@p.pet_id</td>
                <td>
                    <div class="fw-bold text-success fs-6">@p.pet_name</div>
                </td>
                <td>
                    <div class="fw-bold text-primary">@p.species - @p.breed</div>
                    <div class="small text-muted"><i class="bi bi-calendar3"></i> @(p.birth_date?.ToString("dd/MM/yyyy") ?? "N/A")</div>
                </td>
                <td>
                    <span class="badge bg-light text-dark border">@p.gender</span>
                    <span class="badge bg-light text-dark border">@p.color</span>
                    <span class="badge bg-light text-dark border">@(p.weight?.ToString("0.##") ?? "0") kg</span>
                </td>
                <td class="text-muted small">@p.note</td>
                <td>
                    <div class="fw-bold text-dark">
                        <i class="bi bi-person-circle text-secondary me-1"></i> @p.customer_id - @p.owner_name
                    </div>
                    <div class="small text-muted ms-4">
                        <i class="bi bi-phone me-1"></i> @(string.IsNullOrEmpty(p.owner_phone) ? "XXX" : p.owner_phone)
                    </div>
                </td>
                <td class="text-center text-nowrap">
                    <button class="btn btn-sm btn-warning me-2" @onclick="() => EditPet(p)"><i class="bi bi-pencil-square"></i></button>
                    <button class="btn btn-sm btn-danger" @onclick="() => DeletePet(p)"><i class="bi bi-trash3-fill"></i></button>
                </td>
            </tr>
        }
    </tbody>
</table>


<div class="d-flex justify-content-end align-items-center mt-3 bg-light p-2 rounded shadow-sm">
    <div class="btn-group">
        <button class="btn btn-sm btn-outline-primary" @onclick="() => currentPage = 1" disabled="@(currentPage == 1)">
            <i class="bi bi-chevron-double-left"></i>
        </button>
        <button class="btn btn-sm btn-outline-primary" @onclick="() => currentPage--" disabled="@(currentPage == 1)">
            <i class="bi bi-chevron-left"></i>
        </button>
        <span class="btn btn-sm btn-white disabled px-3">Trang @currentPage / @totalPages</span>
        <button class="btn btn-sm btn-outline-primary" @onclick="() => currentPage++" disabled="@(currentPage >= totalPages)">
            <i class="bi bi-chevron-right"></i>
        </button>
        <button class="btn btn-sm btn-outline-primary" @onclick="() => currentPage = totalPages" disabled="@(currentPage >= totalPages)">
            <i class="bi bi-chevron-double-right"></i>
        </button>
    </div>
</div>

@code {
    [Inject] IJSRuntime JSRuntime { get; set; }
    private List<PetDisplay> pets = new();
    private List<CustomerDisplay> customers = new();
    private List<CustomerDisplay> suggestedCustomers = new();

    private PetDisplay currentPet = new();
    private bool isEditing = false;
    private string searchText = "";
    private string ownerSearchKeyword = "";
    private string selectedOwnerName = "";
    private int pageSize = 20;
    private int currentPage = 1;
    private int totalPages => Math.Max(1, (int)Math.Ceiling((double)FilteredPetsRaw.Count() / pageSize));

    private string baseUrl = "/api";

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync("datepicker.init", "pet_birth_date_picker", false);
        }
    }

    private async Task LoadData()
    {
        try
        {
            var t1 = Http.GetFromJsonAsync<List<CustomerDisplay>>($"{baseUrl}/customers");
            var t2 = Http.GetFromJsonAsync<List<PetDisplay>>($"{baseUrl}/pets");
            await Task.WhenAll(t1, t2);

            customers = await t1 ?? new();
            pets = await t2 ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Lỗi load data: {ex.Message}");
        }
    }

    private IEnumerable<PetDisplay> FilteredPetsRaw => pets.Where(p =>
    {
        if (string.IsNullOrEmpty(searchText)) return true;
        var term = searchText.ToLower();
        return p.customer_id.ToString().Contains(term) ||
               (p.pet_name != null && p.pet_name.ToLower().Contains(term));
    });

    private IEnumerable<PetDisplay> PagedPets => FilteredPetsRaw
        .Skip((currentPage - 1) * pageSize)
        .Take(pageSize);

    private void SearchOwner()
    {
        if (string.IsNullOrWhiteSpace(ownerSearchKeyword))
        {
            suggestedCustomers.Clear();
            return;
        }
        var key = ownerSearchKeyword.ToLower();
        suggestedCustomers = customers.Where(c => c.customer_id.ToString().Contains(key) || (c.FullName != null && c.FullName.ToLower().Contains(key))).Take(5).ToList();
    }

    private void SelectOwner(CustomerDisplay c)
    {
        currentPet.customer_id = c.customer_id;
        selectedOwnerName = $"{c.FullName} ({c.phone})";
        suggestedCustomers.Clear();
        ownerSearchKeyword = "";
    }

    private void RemoveOwner()
    {
        currentPet.customer_id = 0;
        selectedOwnerName = "";
    }

    private async Task SavePet()
    {
        if (string.IsNullOrEmpty(currentPet.species) || currentPet.customer_id == 0) return;

        if (isEditing)
        {
            await Http.PutAsJsonAsync($"{baseUrl}/pets/{currentPet.pet_id}", currentPet);
        }
        else
        {
            await Http.PostAsJsonAsync($"{baseUrl}/pets", currentPet);
        }

        await LoadData();
        currentPet = new();
        RemoveOwner();
        isEditing = false;
    }

    private void EditPet(PetDisplay p)
    {
        currentPet = new PetDisplay
            {
                pet_id = p.pet_id,
                pet_name = p.pet_name,
                species = p.species,
                breed = p.breed,
                color = p.color,
                weight = p.weight,
                birth_date = p.birth_date,
                gender = p.gender,
                note = p.note,
                customer_id = p.customer_id
            };

        var owner = customers.FirstOrDefault(c => c.customer_id == p.customer_id);
        if (owner != null)
        {
            selectedOwnerName = $"{owner.FullName} ({owner.phone})";
        }
        else
        {
            selectedOwnerName = "Không xác định";
        }
        isEditing = true;
    }

    private void CancelEdit()
    {
        currentPet = new();
        RemoveOwner();
        isEditing = false;
    }

    private async Task DeletePet(PetDisplay p)
    {
        await Http.DeleteAsync($"{baseUrl}/pets/{p.pet_id}");
        await LoadData();
    }
}

