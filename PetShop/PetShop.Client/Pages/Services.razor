@page "/services"
<PageTitle>Dịch Vụ</PageTitle>
@using PetShop.DTO
@using System.Net.Http.Json
@inject HttpClient Http
@inject IJSRuntime JSRuntime
@inject NavigationManager Nav

<h3 class="text-primary mb-4">
    <i class="bi bi-scissors me-2"></i> DANH SÁCH DỊCH VỤ
</h3>

<div class="card p-3 mb-4 shadow-sm bg-light">
    <div class="row g-2 align-items-end">
        <div class="col-md-4">
            <label class="form-label fw-bold small">Tên Dịch Vụ</label>
            <input @bind="currentService.service_name" class="form-control" placeholder="VD: Tắm gội toàn thân..." />
        </div>

        <div class="col-md-3">
            <label class="form-label fw-bold small">Thời Gian (Phút)</label>
            <div class="input-group">
                <input @bind="currentService.estimated_duration" type="number" class="form-control" placeholder="VD: 30" />
                <span class="input-group-text"><i class="bi bi-clock"></i></span>
            </div>
        </div>

        <div class="col-md-3">
            <label class="form-label fw-bold small">Giá Dịch Vụ</label>
            <div class="input-group">
                <input @bind="FormattedCurrentPrice" @bind:event="oninput" type="text" class="form-control" placeholder="0" />
                <span class="input-group-text">VNĐ</span>
            </div>
        </div>

        <div class="col-md-2">
            @if (isEditing)
            {
                <div class="d-flex gap-1">
                    <button class="btn btn-success w-100" @onclick="SaveService" title="Lưu"><i class="bi bi-check-lg"></i></button>
                    <button class="btn btn-secondary w-100" @onclick="CancelEdit" title="Hủy"><i class="bi bi-x-lg"></i></button>
                </div>
            }
            else
            {
                <button class="btn btn-primary w-100" @onclick="SaveService" title="Thêm mới"><i class="bi bi-plus-circle"></i></button>
            }
        </div>
    </div>
</div>

<table class="table table-bordered table-hover align-middle shadow-sm">
    <thead class="table-primary text-center">
        <tr>
            <th style="width: 50px;">ID</th>
            <th class="text-start">Tên Dịch Vụ</th>
            <th style="width: 150px;">Thời Gian</th>
            <th style="width: 200px;">Giá Niêm Yết</th>
            <th style="width: 150px;">Thao Tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var s in services)
        {
            <tr>
                <td class="text-center fw-bold text-secondary">@s.service_id</td>
                <td><span class="fw-bold text-dark">@s.service_name</span></td>
                <td class="text-center text-muted">@s.estimated_duration phút</td>
                <td class="text-end fw-bold text-success">@s.current_price.ToString("#,##0") đ</td>
                <td class="text-center">
                    <button class="btn btn-sm btn-warning me-2" @onclick="() => EditService(s)"><i class="bi bi-pencil-square"></i></button>
                    <button class="btn btn-sm btn-danger" @onclick="() => DeleteService(s)"><i class="bi bi-trash3-fill"></i></button>
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    private List<ServiceDisplay> services = new();
    private ServiceDisplay currentService = new();
    private bool isEditing = false;

    private string apiUrl = "/api/services";

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var userJson = await JSRuntime.InvokeAsync<string>("sessionStorage.getItem", "user");
            if (string.IsNullOrEmpty(userJson) || (!userJson.Contains("Quản") && !userJson.Contains("Admin")))
            {
                Nav.NavigateTo("/");
            }
        }
    }

    private string FormattedCurrentPrice
    {
        get => currentService.current_price == 0 ? "" : currentService.current_price.ToString("#,##0").Replace(",", ".");
        set
        {
            var stringValue = value.Replace(".", "").Replace(",", "");
            if (decimal.TryParse(stringValue, out var val)) currentService.current_price = val;
            else currentService.current_price = 0;
        }
    }

    private async Task LoadData()
    {
        try
        {
            services = await Http.GetFromJsonAsync<List<ServiceDisplay>>(apiUrl) ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Lỗi load data: {ex.Message}");
        }
    }

    private async Task SaveService()
    {
        if (!string.IsNullOrEmpty(currentService.service_name) && currentService.current_price >= 0)
        {
            if (isEditing)
            {
                await Http.PutAsJsonAsync($"{apiUrl}/{currentService.service_id}", currentService);
            }
            else
            {
                await Http.PostAsJsonAsync(apiUrl, currentService);
            }
            currentService = new();
            isEditing = false;
            await LoadData();
        }
    }

    private void EditService(ServiceDisplay s)
    {
        currentService = new ServiceDisplay
            {
                service_id = s.service_id,
                service_name = s.service_name,
                estimated_duration = s.estimated_duration,
                current_price = s.current_price
            };
        isEditing = true;
    }

    private void CancelEdit()
    {
        currentService = new();
        isEditing = false;
    }

    private async Task DeleteService(ServiceDisplay s)
    {
        var response = await Http.DeleteAsync($"{apiUrl}/{s.service_id}");
        if (response.IsSuccessStatusCode)
        {
            await LoadData();
        }
    }
}

