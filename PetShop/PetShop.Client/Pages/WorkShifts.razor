@page "/workshifts"
<PageTitle>Ca Làm Việc</PageTitle>
@using PetShop.DTO
@using System.Net.Http.Json
@inject HttpClient Http

<h3 class="text-primary mb-4"><i class="bi bi-calendar3-range me-2"></i> QUẢN LÝ CA LÀM VIỆC</h3>

<div class="card p-3 mb-4 shadow-sm bg-light">
    <div class="row g-3 align-items-end">
        <div class="col-md-4">
            <label class="form-label fw-bold small">Nhân viên trực ca</label>
            <select @bind="currentShift.employee_id" class="form-select">
                <option value="0">-- Chọn nhân viên --</option>
                @foreach (var e in FilteredEmployees)
                {
                    <option value="@e.employee_id">@e.employee_id - @e.FullName</option>
                }
            </select>
        </div>

        <div class="col-md-3">
            <label class="form-label fw-bold small">Bắt đầu</label>
            <input id="start_time_picker" @bind="currentShift.start_time" @bind:format="yyyy-MM-dd HH:mm" type="text" class="form-control" placeholder="Chọn thời gian bắt đầu..." />
        </div>

        <div class="col-md-3">
            <label class="form-label fw-bold small">Kết thúc</label>
            <input id="end_time_picker" @bind="currentShift.end_time" @bind:format="yyyy-MM-dd HH:mm" type="text" class="form-control" placeholder="Chọn thời gian kết thúc..." />
        </div>

        <div class="col-md-2">
            @if (isEditing)
            {
                <div class="d-flex gap-1">
                    <button class="btn btn-success w-100" @onclick="SaveShift"><i class="bi bi-check-lg"></i></button>
                    <button class="btn btn-secondary w-100" @onclick="CancelEdit"><i class="bi bi-x-lg"></i></button>
                </div>
            }
            else
            {
                <button class="btn btn-primary w-100" @onclick="SaveShift"><i class="bi bi-plus-lg"></i> Thêm Ca</button>
            }
        </div>
    </div>
</div>

<table class="table table-bordered table-hover align-middle shadow-sm">
    <thead class="table-primary text-center">
        <tr>
            <th>ID Ca</th>
            <th>Nhân Viên</th>
            <th>Bắt Đầu</th>
            <th>Kết Thúc</th>
            <th>Thời Lượng</th>
            <th>Thao Tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var w in PagedShifts)
        {
            var duration = w.end_time - w.start_time;
            <tr>
                <td class="text-center fw-bold text-secondary">@w.workshift_id</td>
                <td>
                    <div class="fw-bold text-primary"><i class="bi bi-person-badge me-1"></i> @w.employee_name</div>
                </td>
                <td class="text-center">@w.start_time.ToString("dd/MM/yyyy HH:mm")</td>
                <td class="text-center">@w.end_time.ToString("dd/MM/yyyy HH:mm")</td>
                <td class="text-center text-muted">
                    @(duration.TotalHours > 0 ? $"{duration.TotalHours:0.0} giờ" : "Lỗi giờ")
                </td>
                <td class="text-center text-nowrap">
                    <button class="btn btn-sm btn-warning me-2" @onclick="() => EditShift(w)"><i class="bi bi-pencil-square"></i></button>
                    <button class="btn btn-sm btn-danger" @onclick="() => DeleteShift(w)"><i class="bi bi-trash3-fill"></i></button>
                </td>
            </tr>
        }
    </tbody>
</table>


<div class="d-flex justify-content-end align-items-center mt-3 bg-light p-2 rounded shadow-sm">
    <div class="btn-group">
        <button class="btn btn-sm btn-outline-primary" @onclick="() => currentPage = 1" disabled="@(currentPage == 1)">
            <i class="bi bi-chevron-double-left"></i>
        </button>
        <button class="btn btn-sm btn-outline-primary" @onclick="() => currentPage--" disabled="@(currentPage == 1)">
            <i class="bi bi-chevron-left"></i>
        </button>
        <span class="btn btn-sm btn-white disabled px-3">Trang @currentPage / @totalPages</span>
        <button class="btn btn-sm btn-outline-primary" @onclick="() => currentPage++" disabled="@(currentPage >= totalPages)">
            <i class="bi bi-chevron-right"></i>
        </button>
        <button class="btn btn-sm btn-outline-primary" @onclick="() => currentPage = totalPages" disabled="@(currentPage >= totalPages)">
            <i class="bi bi-chevron-double-right"></i>
        </button>
    </div>
</div>

@code {
    [Inject] IJSRuntime JSRuntime { get; set; }
    private List<WorkShiftDisplay> workshifts = new();
    private List<EmployeeDisplay> employees = new();
    private IEnumerable<EmployeeDisplay> FilteredEmployees => employees.Where(e =>
    {
        if (string.IsNullOrEmpty(e.role_name)) return true;
        var r = e.role_name.ToLower();
        return !r.Contains("quản lý") && !r.Contains("cskh") && !r.Contains("lễ tân") && !r.Contains("bán hàng") && e.role_id != 1 && e.is_active;
    });
    private WorkShiftDisplay currentShift = new() { start_time = DateTime.Now, end_time = DateTime.Now.AddHours(1) };
    private bool isEditing = false;
    private string errorMessage = "";
    private int pageSize = 20;
    private int currentPage = 1;
    private int totalPages => Math.Max(1, (int)Math.Ceiling((double)workshifts.Count / pageSize));
    private IEnumerable<WorkShiftDisplay> PagedShifts => workshifts.Skip((currentPage - 1) * pageSize).Take(pageSize);

    protected override async Task OnInitializedAsync()
    {
        employees = await Http.GetFromJsonAsync<List<EmployeeDisplay>>("/api/employees") ?? new();
        await LoadData();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync("datepicker.init", "start_time_picker", true);
            await JSRuntime.InvokeVoidAsync("datepicker.init", "end_time_picker", true);
        }
    }

    private async Task LoadData()
    {
        workshifts = await Http.GetFromJsonAsync<List<WorkShiftDisplay>>("/api/workshifts") ?? new();
    }

    private async Task SaveShift()
    {
        errorMessage = "";
        if (currentShift.employee_id == 0)
        {
            errorMessage = "Vui lòng chọn nhân viên trực ca!";
            return;
        }

        if (currentShift.end_time <= currentShift.start_time)
        {
            errorMessage = "Thời gian kết thúc phải lớn hơn thời gian bắt đầu!";
            return;
        }

        try
        {
            HttpResponseMessage response;
            if (isEditing)
            {
                response = await Http.PutAsJsonAsync($"/api/workshifts/{currentShift.workshift_id}", currentShift);
            }
            else
            {
                response = await Http.PostAsJsonAsync("/api/workshifts", currentShift);
            }

            if (response.IsSuccessStatusCode)
            {
                currentShift = new() { start_time = DateTime.Now, end_time = DateTime.Now.AddHours(1) };
                isEditing = false;
                await LoadData();
            }
        }
        catch (Exception)
        {
        }
    }

    private void EditShift(WorkShiftDisplay w)
    {
        currentShift = new WorkShiftDisplay
            {
                workshift_id = w.workshift_id,
                employee_id = w.employee_id,
                start_time = w.start_time,
                end_time = w.end_time
            };
        isEditing = true;
    }

    private void CancelEdit()
    {
        currentShift = new();
        isEditing = false;
    }

    private async Task DeleteShift(WorkShiftDisplay w)
    {
        await Http.DeleteAsync($"/api/workshifts/{w.workshift_id}");
        await LoadData();
    }
}

