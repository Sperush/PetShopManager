@page "/pos"
@using PetShop_Management.Models
@using PetShop_Management.DTOs
@inject HttpClient Http
@inject IJSRuntime JS

<PageTitle>Quầy Thu Ngân</PageTitle>

<div class="container-fluid mt-3">
    <div class="row">
        <div class="col-md-8">
            <h4 class="mb-3"><i class="bi bi-box-seam"></i> Danh sách Sản phẩm</h4>

            @if (products == null)
            {
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            }
            else
            {
                <div class="row row-cols-1 row-cols-md-3 g-3">
                    @foreach (var prod in products)
                    {
                        <div class="col">
                            <div class="card h-100 shadow-sm">
                                <div class="card-body">
                                    <h5 class="card-title text-primary">@prod.Name</h5>
                                    <p class="card-text mb-1">
                                        Giá: <strong class="text-danger">@prod.Price.ToString("N0") VNĐ</strong>
                                    </p>
                                    <p class="card-text">
                                        <small class="text-muted">Tồn kho: @prod.Stock</small>
                                    </p>
                                    <button class="btn btn-outline-success w-100"
                                    @onclick="() => AddToCart(prod)"
                                    disabled="@(prod.Stock <= 0)">
                                        <i class="bi bi-cart-plus"></i> Thêm vào giỏ
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <div class="col-md-4">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h5 class="card-title mb-0"><i class="bi bi-cart4"></i> Hóa Đơn Bán Lẻ</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Khách hàng</label>

                        @if (currCustomer.Id < 0)
                        {
                            <div class="position-relative">
                                <div class="input-group">
                                    <input class="form-control"
                                    placeholder="Nhập ID Khách..."
                                    @bind="ownerSearchKeyword"
                                    @bind:event="oninput"
                                    @onkeyup="SearchOwner" />
                                </div>

                                @if (suggestedCustomers.Any())
                                {
                                    <div class="list-group position-absolute w-100 shadow" style="z-index: 1000; max-height: 200px; overflow-y: auto;">
                                        @foreach (var c in suggestedCustomers)
                                        {
                                            <button type="button" class="list-group-item list-group-item-action"
                                            @onclick="() => SelectOwner(c)">
                                                <div class="d-flex justify-content-between">
                                                    <strong>ID: @c.Id - @c.Name</strong>
                                                    <small class="text-muted">@c.Phone</small>
                                                </div>
                                            </button>
                                        }
                                    </div>
                                }
                                else if (!string.IsNullOrEmpty(ownerSearchKeyword) && ownerSearchKeyword.Length > 1)
                                {
                                    <div class="text-danger small mt-1">Không tìm thấy ai...</div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="input-group">
                                <span class="form-control bg-light text-primary fw-bold">
                                    <i class="bi bi-person-check-fill"></i> @selectedOwnerName
                                </span>
                                <button class="btn btn-outline-danger" type="button" @onclick="RemoveOwner">
                                    <i class="bi bi-x-lg"></i>
                                </button>
                            </div>
                        }
                    </div>

                    <table class="table table-sm mt-3">
                        <thead>
                            <tr>
                                <th>Tên món</th>
                                <th style="width: 80px;">SL</th>
                                <th class="text-end">Thành tiền</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (cart.Count == 0)
                            {
                                <tr><td colspan="4" class="text-center text-muted">Giỏ hàng trống</td></tr>
                            }
                            else
                            {
                                @foreach (var item in cart)
                                {
                                    <tr>
                                        <td>@item.ProductName</td>
                                        <td>
                                            <input type="number" class="form-control form-control-sm"
                                            @bind="item.Quantity" @bind:event="oninput" min="1" />
                                        </td>
                                        <td class="text-end">@((item.Price * item.Quantity).ToString("N0"))</td>
                                        <td>
                                            <button class="btn btn-sm btn-danger" @onclick="() => RemoveFromCart(item)">
                                                <i class="bi bi-x"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>

                    <hr />
                    <div class="d-flex justify-content-between mb-3">
                        <span class="fw-bold fs-5">Tổng tiền:</span>
                        <span class="fw-bold fs-5 text-danger">@CalculateTotal().ToString("N0") VNĐ</span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Phương thức thanh toán</label>
                        <select class="form-select" @bind="paymentMethod">
                            <option value="Tiền mặt">Tiền mặt</option>
                            <option value="Chuyển khoản">Chuyển khoản</option>
                        </select>
                    </div>

                    <button class="btn btn-success w-100 btn-lg"
                    @onclick="Checkout"
                            disabled="@(cart.Count == 0 || currCustomer.Id < 0)">
                        <i class="bi bi-cash-coin"></i> THANH TOÁN
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string searchText = "";
    private string ownerSearchKeyword = "";
    private string selectedOwnerName = "";
    private string paymentMethod = "Tiền mặt";
    private Customer currCustomer = new Customer() { Id = -1 };
    private List<Customer>? customers;
    private List<Customer> suggestedCustomers = new List<Customer>();
    private List<Product>? products;
    private List<CartItemDTO> cart = new List<CartItemDTO>();

    protected override async Task OnInitializedAsync()
    {
        products = await Http.GetFromJsonAsync<List<Product>>("https://localhost:7225/api/products");
        customers = await Http.GetFromJsonAsync<List<Customer>>("https://localhost:7225/api/customers");
    }

    private void AddToCart(Product prod)
    {
        var existingItem = cart.FirstOrDefault(c => c.ProductId == prod.Id);
        if (existingItem != null)
        {
            existingItem.Quantity++;
        }
        else
        {
            cart.Add(new CartItemDTO
            {
                ProductId = prod.Id,
                ProductName = prod.Name,
                Price = prod.Price,
                Quantity = 1
            });
        }
    }

    private void RemoveFromCart(CartItemDTO item)
    {
        cart.Remove(item);
    }

    private decimal CalculateTotal()
    {
        return cart.Sum(item => item.Price * item.Quantity);
    }
    private void SearchOwner()
    {
        if (string.IsNullOrWhiteSpace(ownerSearchKeyword))
        {
            suggestedCustomers.Clear();
            return;
        }
        var key = ownerSearchKeyword.ToLower();
        suggestedCustomers = customers.Where(c => c.Id.ToString().Contains(key)).Take(5).ToList();
    }

    private void SelectOwner(Customer c)
    {
        currCustomer.Id = c.Id;
        selectedOwnerName = $"{c.Name} ({c.Phone})";
        suggestedCustomers.Clear();
        ownerSearchKeyword = "";
    }

    private void RemoveOwner()
    {
        currCustomer.Id = -1;
        selectedOwnerName = "";
    }

    private async Task Checkout()
    {
        if (currCustomer.Id < 0)
        {
            await JS.InvokeVoidAsync("alert", "Vui lòng chọn khách hàng!");
            return;
        }
        var orderRequest = new OrderRequest
        {
            CustomerId = currCustomer.Id,
            PaymentMethod = paymentMethod,
            CartItems = this.cart
        };
        var response = await Http.PostAsJsonAsync("https://localhost:7225/api/orders", orderRequest);
        if (response.IsSuccessStatusCode)
        {
            await JS.InvokeVoidAsync("alert", "Thanh toán thành công! Tồn kho đã được trừ.");
            cart.Clear();
            currCustomer.Id = -1;
            products = await Http.GetFromJsonAsync<List<Product>>("https://localhost:7225/api/products");
        }
        else
        {
            var error = await response.Content.ReadAsStringAsync();
            await JS.InvokeVoidAsync("alert", "Lỗi: " + error);
        }
    }
}